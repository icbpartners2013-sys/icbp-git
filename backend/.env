# MongoDB Atlas Connection
# Note: If SRV connection fails locally due to DNS issues, 
# you can use a direct connection string format.
# Get the direct connection string from MongoDB Atlas:
# Clusters -> Connect -> Connect your application -> Driver -> Version 3.6 or later
# Then copy the connection string and replace the placeholder below.

# SRV Connection (works on Render, may fail locally on some networks)

MONGO_URI=mongodb+srv://icbpartners2013_db_user:vge7sPGujXVFtp8Y@icbp-mongodb.rbtxg6z.mongodb.net/?appName=icbp-mongodb
# MONGO_URI=mongodb+srv://icbpartners2013_db_user:vge7sPGujXVFtp8Y@icbp-mongodb.rbtxg6z.mongodb.net/?appName=icbp-mongodb
# MONGO_URI=mongodb://icbpartners2013_db_user:vge7sPGujXVFtp8Y@icbp-mongodb-shard-00-00.rbtxg6z.mongodb.net:27017,icbp-mongodb-shard-00-01.rbtxg6z.mongodb.net:27017,icbp-mongodb-shard-00-02.rbtxg6z.mongodb.net:27017/myFirstDatabase?ssl=true&replicaSet=atlas-your-replica-set-name&authSource=admin&retryWrites=true&w=majority


# Alternative: Direct connection (if SRV fails, uncomment and update below)
# Get your cluster hosts from MongoDB Atlas and use this format:
# MONGO_URI=mongodb://icbpartners2013_db_user:vge7sPGujXVFtp8Y@cluster0-shard-00-00.rbtxg6z.mongodb.net:27017,cluster0-shard-00-01.rbtxg6z.mongodb.net:27017,cluster0-shard-00-02.rbtxg6z.mongodb.net:27017/icbp?ssl=true&replicaSet=atlas-xxxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
# MONGO_URI=mongodb://icbpartners2013_db_user:vge7sPGujXVFtp8Y@icbp-mongodb-shard-00-00.rbtxg6z.mongodb.net:27017,icbp-mongodb-shard-00-01.rbtxg6z.mongodb.net:27017,icbp-mongodb-shard-00-02.rbtxg6z.mongodb.net:27017/myFirstDatabase?ssl=true&replicaSet=atlas-your-replica-set-name&authSource=admin&retryWrites=true&w=majority

PORT=5000
JWT_SECRET=icbp-jwt-secret-key-2024 